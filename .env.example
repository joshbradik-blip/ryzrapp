# Supabase — get these from your project at supabase.com > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Anthropic — get this from console.anthropic.com
# For production: store this in a Supabase Edge Function, never ship in the app bundle
EXPO_PUBLIC_ANTHROPIC_KEY=sk-ant-your-key-here

# ExerciseDB — rapidapi.com > ExerciseDB by Justin-Theophile > Subscribe (free tier)
EXPO_PUBLIC_EXERCISEDB_KEY=your_rapidapi_key_here
