{
  "cli": {
    "appVersionSource": "app.json"
  },
  "expo": {
    "name": "RYZR",
    "slug": "ryzrapp",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ryzr.app",
      "buildNumber": "6",
      "infoPlist": {
        "NSCameraUsageDescription": "RYZR uses your camera to analyze your workout form in real-time.",
        "NSMicrophoneUsageDescription": "RYZR uses audio for voice coaching feedback.",
        "NSPhotoLibraryUsageDescription": "RYZR can save workout clips to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ryzr.app",
      "versionCode": 10,
      "minSdkVersion": 28,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withPrismSDK",
      "./plugins/withAdiRegistration",
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "RYZR uses your camera to analyze your workout form in real-time."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "RYZR uses your camera to analyze your workout form in real-time.",
          "enableMicrophonePermission": false,
          "enableLocation": false,
          "enableFrameProcessors": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00FF88"
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "b0b5de98-cbf0-4c33-8080-5726cd0708d2"
      }
    }
  }
}
